# Copy this file to .env.local and adjust the values for your environment
#
#   cp .env.local.example .env.local

# Vite dev server port (default: 5173)
VITE_DEV_PORT=5173

# Backend server URL to proxy API requests to
VITE_PROXY_TARGET=http://localhost:8000

# Hosts allowed to access the Vite dev server
# Comma-separated list: localhost, .local domains, and any remote machine IPs
VITE_ALLOWED_HOSTS=localhost,.local
